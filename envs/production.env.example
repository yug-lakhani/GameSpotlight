# Consolidated production environment variables (example)
# Copy to CI secrets or a non-committed `.env` for local testing.
# NEVER commit real credentials to the repository.

# --------------------------
# Database: Postgres (auth/purchase)
# Services: auth-user-service, purchase-service
# --------------------------
POSTGRES_JDBC_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --------------------------
# MongoDB URIs (per-service)
# Services: auth, game, purchase, wishlist, storage
# --------------------------
AUTH_MONGO_URI=
GAME_MONGO_URI=
PURCHASE_MONGO_URI=
WISHLIST_MONGO_URI=
STORAGE_MONGO_URI=
# Note: some services read a generic MONGO_URI; if so, set MONGO_URI to the appropriate value.
MONGO_URI=

# --------------------------
# JWT
# --------------------------
JWT_SECRET=
JWT_EXPIRATION_SECONDS=604800

# --------------------------
# Kafka (Aiven)
# --------------------------
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=
KAFKA_API_SECRET=
KAFKA_TRUSTSTORE_LOCATION=

# --------------------------
# Redis
# --------------------------
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_SSL=false

# --------------------------
# Mail (Brevo / SMTP)
# --------------------------
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=

# --------------------------
# Supabase / Storage
# --------------------------
AUTH_SUPABASE_URL=
AUTH_SUPABASE_ANON_KEY=
STORAGE_SUPABASE_URL=
STORAGE_SUPABASE_KEY=
SUPABASE_BUCKET_GAME_FILES=game-files
SUPABASE_BUCKET_GAME_IMAGES=game-images

# Alternative storage provider variables (S3/GCS)
STORAGE_PROVIDER=local
STORAGE_BUCKET_NAME=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --------------------------
# Service URLs (for inter-service calls / Docker Compose)
# --------------------------
AUTH_USER_SERVICE_URL=
GAME_SERVICE_URL=
STORAGE_SERVICE_URL=
PURCHASE_SERVICE_URL=
WISHLIST_SERVICE_URL=

# --------------------------
# OpenSearch (optional)
# --------------------------
OPENSEARCH_ENABLED=false
OPENSEARCH_SCHEME=https
OPENSEARCH_HOST=
OPENSEARCH_PORT=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=games
OPENSEARCH_REBUILD_ON_STARTUP=false
OPENSEARCH_BACKFILL_ON_STARTUP=false
OPENSEARCH_SYNC_ENABLED=true

# --------------------------
# Postgres / Flyway (if running migrations locally)
# --------------------------
# Note: Flyway migrations are run from CI by default. If running locally, provide these.
# (reuse POSTGRES_JDBC_URL / POSTGRES_USER / POSTGRES_PASSWORD)

# --------------------------
# Runtime / Misc
# --------------------------
PORT=
IMAGE_PREFIX=ghcr.io/<your-org>

# --------------------------
# Usage notes
# --------------------------
# - Set `KAFKA_TRUSTSTORE_LOCATION` to a path inside the container or mount the cert via secrets.
# - Align Mongo env names: some services expect `MONGO_URI`, others expect per-service names (e.g., GAME_MONGO_URI).
#   To be safe, set both the generic `MONGO_URI` (used by services that expect it) and the per-service variables.
# - Keep secrets (keys/passwords) only in CI secret stores, not in repo files.
