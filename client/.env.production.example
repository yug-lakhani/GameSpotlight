# Production environment variables (example)
# Use a single API root for the public gateway (free-only Option A).
# `VITE_API_ROOT` should point to the gateway base (no trailing `/api`).
VITE_API_ROOT=https://api.example.com

# Supabase keys (only if using Supabase in production; keep secrets out of repo)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
