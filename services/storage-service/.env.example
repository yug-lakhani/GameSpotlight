# Storage Service Environment Variables

# Database
STORAGE_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/storage-db?retryWrites=true&w=majority

# AWS S3 or equivalent cloud storage
STORAGE_PROVIDER=local  # or 's3', 'gcs', etc.
STORAGE_BUCKET_NAME=<bucket_name>
STORAGE_ACCESS_KEY=<access_key>
STORAGE_SECRET_KEY=<secret_key>

# Supabase (optional)
# Supabase (storage service project)
STORAGE_SUPABASE_URL=
STORAGE_SUPABASE_KEY=
SUPABASE_BUCKET_GAME_FILES=game-files
SUPABASE_BUCKET_GAME_IMAGES=game-images

PORT=8085
