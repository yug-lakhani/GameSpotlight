# ============================================================================
# Services-wide Environment Variables (EXAMPLE)
# ============================================================================
# IMPORTANT: Copy this file to `.env` and fill with REAL VALUES.
#            NEVER commit `.env` with actual credentials to GitHub.
# ============================================================================

# ============================================================================
# DATABASE: MongoDB Atlas URIs
# ============================================================================
AUTH_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/auth-user-db?retryWrites=true&w=majority
GAME_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/game-db?retryWrites=true&w=majority
PURCHASE_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/purchase-db?retryWrites=true&w=majority
WISHLIST_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/wishlist-db?retryWrites=true&w=majority
STORAGE_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/storage-db?retryWrites=true&w=majority

# ============================================================================
# JWT Configuration (shared across services)
# ============================================================================
# Minimum 32 characters; generate with: openssl rand -base64 32
JWT_SECRET=<32_char_min_secret_or_base64>
JWT_EXPIRATION_SECONDS=604800  # 7 days

# ============================================================================
# Kafka Cloud (Aiven) Configuration
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=<host>:<port>
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=<aiven_api_key>
KAFKA_API_SECRET=<aiven_api_secret>

# ============================================================================
# Redis Cloud Configuration
# ============================================================================
REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>
REDIS_USERNAME=<redis_username>
REDIS_PASSWORD=<redis_password>

# ============================================================================
# Docker Image Registry
# ============================================================================
IMAGE_PREFIX=ghcr.io/<your-org>  # For container registries

# ============================================================================
# Notes
# ============================================================================
# 1. Individual services may override these values in their own .env files
# 2. Keep this file with placeholders — it's safe to commit
# 3. The actual `.env` file (with real values) is ignored by .gitignore
# 4. For local development:
#    - Copy this file to `.env`
#    - Fill in real values
#    - Use: source .env  (or Windows: Get-Content .env | ForEach-Object { if ($_) { $_ } })
# 5. For Docker Compose: env_file directive loads secrets automatically
# ============================================================================