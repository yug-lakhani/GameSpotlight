# Game Service Environment Variables

# Database
GAME_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/game-db?retryWrites=true&w=majority
MONGO_URI=

# JWT
JWT_SECRET=<minimum_32_char_secret_or_base64_secret>
JWT_EXPIRATION_SECONDS=604800

# Kafka (Aiven)
KAFKA_BOOTSTRAP_SERVERS=<host>:<port>
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=<api_key>
KAFKA_API_SECRET=<api_secret>
KAFKA_TRUSTSTORE_LOCATION=

# Redis
REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>
REDIS_USERNAME=<redis_username>
REDIS_PASSWORD=<redis_password>
REDIS_SSL=false

# Service URLs (for Docker Compose)
STORAGE_SERVICE_URL=http://storage:8085/api
AUTH_USER_SERVICE_URL=http://auth-user:8087/api

# OpenSearch
OPENSEARCH_ENABLED=true
OPENSEARCH_SYNC_ENABLED=true

PORT=8082

# OpenSearch connection details (optional)
OPENSEARCH_HOST=
OPENSEARCH_PORT=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=games
OPENSEARCH_SCHEME=https
OPENSEARCH_REBUILD_ON_STARTUP=false
OPENSEARCH_BACKFILL_ON_STARTUP=false
