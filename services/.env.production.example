# Services-wide production environment variables (example)

# MongoDB URIs
AUTH_MONGO_URI=<<AUTH_MONGO_URI>>
GAME_MONGO_URI=<<GAME_MONGO_URI>>
PURCHASE_MONGO_URI=<<PURCHASE_MONGO_URI>>
WISHLIST_MONGO_URI=<<WISHLIST_MONGO_URI>>
STORAGE_MONGO_URI=<<STORAGE_MONGO_URI>>

# Generic Postgres variables used by auth-user-service / purchase-service
POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/auth_db?sslmode=require
POSTGRES_USER=<<POSTGRES_USER>>
POSTGRES_PASSWORD=<<POSTGRES_PASSWORD>>

# PostgreSQL URIs for services that use Postgres
AUTH_POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/auth_db?sslmode=require
AUTH_POSTGRES_USER=<<AUTH_POSTGRES_USER>>
AUTH_POSTGRES_PASSWORD=<<AUTH_POSTGRES_PASSWORD>>
PURCHASE_POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/purchase_db?sslmode=require
PURCHASE_POSTGRES_USER=<<PURCHASE_POSTGRES_USER>>
PURCHASE_POSTGRES_PASSWORD=<<PURCHASE_POSTGRES_PASSWORD>>

# JWT Configuration
JWT_SECRET=<<PROD_JWT_SECRET>>
JWT_EXPIRATION_SECONDS=604800

# Kafka (Aiven) Configuration
KAFKA_BOOTSTRAP_SERVERS=<<PROD_KAFKA_BOOTSTRAP_SERVERS>>
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=<<PROD_KAFKA_API_KEY>>
KAFKA_API_SECRET=<<PROD_KAFKA_API_SECRET>>
KAFKA_TRUSTSTORE_LOCATION=<<KAFKA_TRUSTSTORE_LOCATION>>

# Redis Cloud
REDIS_HOST=<<PROD_REDIS_HOST>>
REDIS_PORT=<<PROD_REDIS_PORT>>
REDIS_USERNAME=<<PROD_REDIS_USERNAME>>
REDIS_PASSWORD=<<PROD_REDIS_PASSWORD>>
REDIS_SSL=false

# Supabase projects (ensure these point to distinct Supabase projects)
# Auth service Supabase project
AUTH_SUPABASE_URL=<<AUTH_SUPABASE_URL>>
AUTH_SUPABASE_ANON_KEY=<<AUTH_SUPABASE_ANON_KEY>>

# Storage service Supabase project (must be a different project than auth)
STORAGE_SUPABASE_URL=<<STORAGE_SUPABASE_URL>>
STORAGE_SUPABASE_KEY=<<STORAGE_SUPABASE_KEY>>

# Mail / SMTP
BREVO_SMTP_USERNAME=<<BREVO_SMTP_USERNAME>>
BREVO_SMTP_PASSWORD=<<BREVO_SMTP_PASSWORD>>
BREVO_SMTP_HOST=<<BREVO_SMTP_HOST>>
BREVO_SMTP_PORT=587
MAIL_FROM_ADDRESS=<<MAIL_FROM_ADDRESS>>

# Service endpoints (internal)
AUTH_USER_SERVICE_URL=<<AUTH_USER_SERVICE_URL>>
GAME_SERVICE_URL=<<GAME_SERVICE_URL>>
STORAGE_SERVICE_URL=<<STORAGE_SERVICE_URL>>

# OpenSearch (game-service)
OPENSEARCH_ENABLED=true
OPENSEARCH_SYNC_ENABLED=true
OPENSEARCH_BACKFILL_ON_STARTUP=false
OPENSEARCH_SCHEME=https
OPENSEARCH_HOST=<<OPENSEARCH_HOST>>
OPENSEARCH_PORT=<<OPENSEARCH_PORT>>
OPENSEARCH_USERNAME=<<OPENSEARCH_USERNAME>>
OPENSEARCH_PASSWORD=<<OPENSEARCH_PASSWORD>>
OPENSEARCH_INDEX=games
