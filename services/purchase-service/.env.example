# Purchase Service Environment Variables

# Database
PURCHASE_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/purchase-db?retryWrites=true&w=majority
# Optional Postgres (same Aiven project as auth-user). Example:
# Postgres (uncomment and fill if using Postgres)
POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/purchase_db?sslmode=verify-ca&sslrootcert=./ca/aiven-ca.pem
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>

# JWT
JWT_SECRET=<minimum_32_char_secret_or_base64_secret>
JWT_EXPIRATION_SECONDS=604800

# Kafka (Aiven)
KAFKA_BOOTSTRAP_SERVERS=<host>:<port>
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_API_KEY=<api_key>
KAFKA_API_SECRET=<api_secret>
KAFKA_TRUSTSTORE_LOCATION=

# Service URLs (for Docker Compose)
AUTH_USER_SERVICE_URL=http://auth-user:8087/api
GAME_SERVICE_URL=http://game:8082/api

PORT=8083

# Redis (for idempotency/cache)
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_SSL=false

# SMTP (Brevo) for transactional email
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
