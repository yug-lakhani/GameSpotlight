# PostgreSQL Database
# Use sslmode=require for basic SSL (no cert verification)
# Use sslmode=verify-ca for production (requires CA cert at path below)
POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/auth_db?sslmode=require
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>

# For sslmode=verify-ca, add: &sslrootcert=./ca/aiven-ca.pem
# Example: POSTGRES_JDBC_URL=jdbc:postgresql://<host>:<port>/auth_db?sslmode=verify-ca&sslrootcert=./ca/aiven-ca.pem

# JWT Secret (minimum 32 characters; will be SHA-256 derived if needed for HS256)
JWT_SECRET=<minimum_32_char_secret_or_base64_secret>
JWT_EXPIRATION_SECONDS=604800

PORT=8087

# Copy this file to `.env` in the same folder for local development and replace values as needed.
# NEVER commit actual credentials — only .env.example with placeholders.

# Supabase (auth service project)
AUTH_SUPABASE_URL=
AUTH_SUPABASE_ANON_KEY=